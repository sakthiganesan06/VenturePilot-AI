# ═══════════════════════════════════════════════════════════════════════════
# AI Startup Blueprint Generator — Environment Variables
# Copy this file to .env and fill in your IBM Cloud credentials
# ═══════════════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-flask-key-change-this
FLASK_DEBUG=false
PORT=5000

# ── IBM watsonx.ai (Granite) ───────────────────────────────────────────────
# Get from: https://cloud.ibm.com/apidocs/watsonx-ai
IBM_WATSONX_API_KEY=7HoD9IIyMfVwhUf3_vl5KytoiRuLY4K9o_fg-aResvIn
IBM_WATSONX_URL=https://au-syd.ml.cloud.ibm.com
IBM_WATSONX_PROJECT_ID=172c0481-6f7b-4aa2-b4b4-2e3ff3c31b80
# Granite model — choose one:
# ibm/granite-3-3-8b-instruct   (recommended — fast, high quality)
# ibm/granite-3-8b-instruct     (stable, production-ready)
# ibm/granite-13b-chat-v2       (larger context)
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── IBM Cloud Object Storage ───────────────────────────────────────────────
# Get from: IBM Cloud → Resource List → Cloud Object Storage → Service Credentials
IBM_COS_API_KEY=7q1XmzDgsa4OTeDBNvcnqxJhjCU72Zb15cKyrXPf7rwN
IBM_COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/b4e8e0f93dfc42378121768e498ce064:313dd5d0-e2c9-4f76-ae1f-57d6ebac60e2::
IBM_COS_ENDPOINT=https://s3.au-syd.cloud-object-storage.appdomain.cloud
IBM_COS_AUTH_ENDPOINT=https://iam.cloud.ibm.com/identity/toke

# COS Bucket Names (create these in your COS instance)
IBM_COS_BUCKET_KB=startup-knowledge-base
IBM_COS_BUCKET_REPORTS=startup-reports
IBM_COS_BUCKET_RESOURCES=startup-resources

# ── RAG / Embeddings ───────────────────────────────────────────────────────
# Sentence Transformer model for vector embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
